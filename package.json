{
  "name": "lambda-processor-template",
  "version": "1.0.0",
  "description": "AWS Lambda template for Arke file processing with async job pattern",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --format=esm --packages=external",
    "build:cjs": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.cjs --format=cjs",
    "type-check": "tsc --noEmit",
    "deploy": "bash ./scripts/deploy.sh",
    "create-table": "bash ./scripts/create-table.sh"
  },
  "dependencies": {
    "@arke-institute/sdk": "^3.6.15",
    "@aws-sdk/client-dynamodb": "^3.712.0",
    "@aws-sdk/client-lambda": "^3.712.0",
    "@aws-sdk/lib-dynamodb": "^3.712.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
